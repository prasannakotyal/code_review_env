# OpenEnv Code Review Environment - Environment Variables
# Copy this file to .env and fill in your values

# Validator-injected key in competition runs
API_KEY=

# Local fallback for manual testing
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=

# Alternative: OpenAI API Key (if using OpenAI endpoints)
# OPENAI_API_KEY=

# LLM API Configuration
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-Coder-32B-Instruct

# Environment Configuration
ENV_BASE_URL=https://prasannakotyal-code-review-env.hf.space

# Task Configuration (optional)
# Leave MY_ENV_TASK unset to run all tasks in one invocation.
MY_ENV_BENCHMARK=my_env

# Inference Settings (optional)
TEMPERATURE=0.0
MAX_TOKENS=300

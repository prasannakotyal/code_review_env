# OpenEnv Code Review Environment - Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Hugging Face API Token
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=

# Alternative: OpenAI API Key (if using OpenAI endpoints)
# OPENAI_API_KEY=

# LLM API Configuration
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Environment Configuration
ENV_BASE_URL=https://prasannakotyal-code-review-env.hf.space

# Task Configuration (optional)
MY_ENV_TASK=style_check
MY_ENV_BENCHMARK=my_env

# Inference Settings (optional)
TEMPERATURE=0.0
MAX_TOKENS=300
MAX_STEPS=5